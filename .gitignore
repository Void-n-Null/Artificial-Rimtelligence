# =============================================================================
# RimWorld Mod .gitignore
# =============================================================================

# =============================================================================
# Build Outputs
# =============================================================================

# Build directories
[Dd]ebug/
[Rr]elease/
[Oo]bj/
[Bb]in/
[Oo]ut/
[Ll]og/
[Ll]ogs/
bld/
artifacts/

# Compiled assemblies (uncomment if you want to track .dll files)
# Comment these out if you want to version control your compiled mod DLLs
**/Assemblies/*.dll
**/Assemblies/*.pdb

# =============================================================================
# Visual Studio / MSBuild
# =============================================================================

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Solution files (often auto-generated for RimWorld mods)
*.sln

# Visual Studio cache/options directory
.vs/

# MSBuild output
*.log
*.binlog
MSBuild_Logs/

# Build results
*_i.c
*_p.c
*_h.h
*.ilk
*.obj
*.iobj
*.pch
*.ipdb
*.pgc
*.pgd
*.rsp
!Directory.Build.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.tlog
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# =============================================================================
# VS Code
# =============================================================================

# VS Code directories (keep config files)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# VS Code obj folder (from RimWorld mod template)
.vscode/obj/

# Local History for VS Code
.history/

# Built VS Code Extensions
*.vsix

# =============================================================================
# .NET / NuGet
# =============================================================================

# .NET Core
project.lock.json
project.fragment.lock.json

# NuGet Packages
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# =============================================================================
# JetBrains Rider / ReSharper
# =============================================================================

_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
.idea/

# =============================================================================
# Mono
# =============================================================================

*.userprefs
mono_crash.*

# =============================================================================
# Code Coverage & Testing
# =============================================================================

*.dotCover
.axoCover/*
!.axoCover/settings.json
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml
[Tt]est[Rr]esult*/
*.VisualState.xml
TestResult.xml
nunit-*.xml
*.trx

# =============================================================================
# OS Generated
# =============================================================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# =============================================================================
# Misc
# =============================================================================

# Backup files
*.bak
*.backup
*~
*.swp
*.swo

# Temporary files
*.tmp
*.temp

# Archives (usually not needed in version control)
*.zip
*.7z
*.rar
*.tar.gz

# =============================================================================
# RimWorld Mod Specific
# =============================================================================

# HugsLib generated logs
HugsLib*.log

# Mod manager cache
ModManager/

# Steam workshop upload cache
.steam_upload/

# Local testing copies
!.gitkeep
